# Azure OpenAI configuration for embedding generation
AZURE_OPENAI_ENDPOINT=https://<your-openai-resource-name>.openai.azure.com/
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Entra ID identities for databases (required for key-less auth)
# Auto-populated by 01b-configure-entra-auth.ps1
# Value: UPN of authenticated user (e.g., user@contoso.com)
AZURE_PG_ENTRA_USER=<user@tenant.onmicrosoft.com>

# PostgreSQL server name (auto-populated)
AZURE_PG_SERVER=pg-vectorbench-brs
# ============================================================================
# Configuration to run benchmark on Databricks Vector Search
# See: SETUP_DATABRICKS_FABRIC.md (Databricks section)

# Databricks PAT Token
# Get from: Workspace → User Settings → Developer → Personal access tokens
DATABRICKS_TOKEN=dapi1234567890abcdefghijklmnopqrstuvwxyz

# Databricks Workspace Host
# Example: https://adb-1234567890123456.azuredatabricks.net
DATABRICKS_HOST=https://adb-xxxxxxxxxxxxx.azuredatabricks.net

# SQL Warehouse ID (for SQL queries)
# Find in: SQL Warehouses → Warehouse ID
DATABRICKS_WAREHOUSE_ID=abc123def456ghi789jkl012

# Lakehouse/Unity Catalog configuration
DATABRICKS_CATALOG=main
DATABRICKS_SCHEMA=vector_benchmark

# ============================================================================
# MICROSOFT FABRIC CONFIGURATION (NEW) ⭐
# ============================================================================
# Configuration to run benchmark on Microsoft Fabric
# See: SETUP_DATABRICKS_FABRIC.md (Fabric section)

# Microsoft Fabric Workspace ID
# Get from: Workspace Settings → Workspace ID
FABRIC_WORKSPACE_ID=a1b2c3d4-e5f6-7890-abcd-ef1234567890

# Microsoft Fabric Lakehouse ID
# Get from: Lakehouse → Properties → Lakehouse ID
# Or extract from URL: .../lakehouse?id=<FABRIC_LAKEHOUSE_ID>
FABRIC_LAKEHOUSE_ID=12345678-1234-1234-1234-123456789012

# Fabric SQL Endpoint Hostname
# Get from: Lakehouse → SQL Endpoint → Server name
# Format: your-endpoint.fabric.microsoft.com
FABRIC_SQL_ENDPOINT=your-sql-endpoint.fabric.microsoft.com

# Fabric Capacity SKU (informational only)
# Typical values: F64, F128, F256, F512, F1024, F2048
FABRIC_CAPACITY=F64
